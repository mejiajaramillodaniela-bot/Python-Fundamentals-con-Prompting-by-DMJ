"""### Función para filtrar números pares

Esta función `filter_even_numbers` toma una lista de números enteros como entrada y devuelve una nueva lista que contiene solo los números pares de la lista original.
"""

def filtrar_pares(numbers):
    """
    Filtra una lista de números enteros y devuelve una nueva lista
    que contiene solo los números pares.

    Args:
        numbers (list): Una lista de números enteros.

    Returns:
        list: Una nueva lista con solo los números pares.
    """
    if not numbers:
        print("Error, lista vacía")
        return []

    even_numbers = []
    has_negatives = False
    all_even_in_original = True

    for num in numbers:
        if num < 0:
            has_negatives = True
        if num % 2 == 0:
            even_numbers.append(num)
        else:
            all_even_in_original = False

    if has_negatives:
        print("Error, lista con negativos")
    if not even_numbers:
        print("Error, lista sin pares")
    elif all_even_in_original:
        print("Error, todos pares")

    return even_numbers

