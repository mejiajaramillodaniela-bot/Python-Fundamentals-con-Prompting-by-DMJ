"""### Función para contar vocales en un string

Esta función `count_vowels` toma un string como entrada y devuelve un diccionario con el conteo de cada vocal (a, e, i, o, u). Ignora mayúsculas y minúsculas, y también los acentos.
"""

import unicodedata

def count_vowels(text):
    """
    Cuenta la ocurrencia de cada vocal (a, e, i, o, u) en un string,
    ignorando mayúsculas/minúsculas y acentos.

    Args:
        text (str): El string de entrada.

    Returns:
        dict: Un diccionario con el conteo de cada vocal.
    """
    vowel_counts = {'a': 0, 'e': 0, 'i': 0, 'o': 0, 'u': 0}

    # Convertir a minúsculas y remover acentos
    text_normalized = unicodedata.normalize('NFKD', text).encode('ascii', 'ignore').decode('utf-8').lower()

    for char in text_normalized:
        if char in vowel_counts:
            vowel_counts[char] += 1

    return vowel_counts

"""### Demostración de la función `count_vowels`"""

# Ejemplos de uso:

