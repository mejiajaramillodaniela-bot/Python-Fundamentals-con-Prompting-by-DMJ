"""### Función para calcular la nota media global

Esta función `calcular_nota_media_global` toma una lista de diccionarios de estudiantes y calcula la nota media de todos ellos.
"""

def calcular_nota_media_global(lista_estudiantes):
    """
    Calcula la nota media global de una lista de estudiantes.

    Args:
        lista_estudiantes (list): Una lista de diccionarios, donde cada diccionario
                                 representa a un estudiante y contiene una clave 'nota'.

    Returns:
        float: La nota media global. Retorna 0.0 si la lista está vacía.
    """
    if not lista_estudiantes:
        return 0.0

    total_notas = sum(estudiante['nota'] for estudiante in lista_estudiantes)
    numero_estudiantes = len(lista_estudiantes)

    return total_notas / numero_estudiantes

