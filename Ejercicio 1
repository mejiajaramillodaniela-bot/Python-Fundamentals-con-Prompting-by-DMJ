"""### Función para calcular la nota media por asignatura

Esta función `calcular_nota_media_por_asignatura` toma una lista de diccionarios de estudiantes y calcula la nota media para cada asignatura, devolviendo un diccionario con los resultados redondeados a dos decimales.
"""

def calcular_nota_media_por_asignatura(lista_estudiantes):
    """
    Calcula la nota media para cada asignatura de una lista de estudiantes.

    Args:
        lista_estudiantes (list): Una lista de diccionarios, donde cada diccionario
                                 representa a un estudiante con claves 'asignatura' y 'nota'.

    Returns:
        dict: Un diccionario donde las claves son los nombres de las asignaturas
              y los valores son las notas medias redondeadas a dos decimales.
              Retorna un diccionario vacío si la lista de estudiantes está vacía.
    """
    if not lista_estudiantes:
        return {}

    notas_por_asignatura = {}

    for estudiante in lista_estudiantes:
        asignatura = estudiante['asignatura']
        nota = estudiante['nota']

        if asignatura not in notas_por_asignatura:
            notas_por_asignatura[asignatura] = {'total_notas': 0, 'conteo_estudiantes': 0}

        notas_por_asignatura[asignatura]['total_notas'] += nota
        notas_por_asignatura[asignatura]['conteo_estudiantes'] += 1

    media_por_asignatura = {}
    for asignatura, datos in notas_por_asignatura.items():
        media = datos['total_notas'] / datos['conteo_estudiantes']
        media_por_asignatura[asignatura] = round(media, 2)

    return media_por_asignatura

"""### Demostración de la función `calcular_nota_media_por_asignatura`"""

